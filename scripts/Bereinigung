import pandas as pd

# Musikdaten
billboard = pd.read_csv("daten/raw/Billboard_Hot100_Songs_Spotify_1946-2022.csv", encoding='latin-1')
billboard['year'] = billboard['Hot100 Ranking Year']
musik = billboard.groupby('year')[['Valence', 'Energy', 'Danceability']].mean().reset_index()

# Wirtschaftsdaten USA
master = pd.read_csv("daten/processed/master.csv")
usa = master[master['Country Code'] == 'USA'][['Jahr', 'GDP', 'Unemployment', 'Inflation']]
usa = usa.rename(columns={'Jahr': 'year'})

# Zusammenführen
combined = musik.merge(usa, on='year')

# Nur 2000-2022
combined = combined[combined['year'].between(2000, 2022)]

# Korrelation
korrelation = combined[['Valence', 'Energy', 'Danceability', 'Unemployment']].corr()

# Speichern
combined.to_csv("daten/processed/musik_wirtschaft_final.csv", index=False, decimal=',', sep=';')
korrelation.to_csv("daten/results/korrelation.csv", decimal=',', sep=';')
# Eskapismus Index
combined['Eskapismus'] = combined['Energy'] - combined['Valence']

print(combined[['year', 'Energy', 'Valence', 'Eskapismus', 'Unemployment']].to_string())

# Folgt Musik der Wirtschaft oder umgekehrt?
combined['Energy_lag1'] = combined['Energy'].shift(1)
combined['Unemployment_lag1'] = combined['Unemployment'].shift(1)

# Korrelation: Unemployment dieses Jahr vs Energy nächstes Jahr
lag_korr = combined['Unemployment'].corr(combined['Energy_lag1'])
print("Unemployment → Energy (1 Jahr später):", lag_korr)

# Korrelation: Energy dieses Jahr vs Unemployment nächstes Jahr  
lag_korr2 = combined['Energy'].corr(combined['Unemployment_lag1'])
print("Energy → Unemployment (1 Jahr später):", lag_korr2)



from scipy import stats

korr, p_wert = stats.pearsonr(combined['Unemployment'].dropna(), combined['Energy'].dropna())
print(f"Korrelation: {korr:.3f}")
print(f"P-Wert: {p_wert:.4f}")
